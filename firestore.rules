rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: users can only read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Allow update but prevent users from changing their own subscriptionStatus
      // (only the webhook Cloud Function running as admin can do that)
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['subscriptionStatus', 'stripeCustomerId', 'stripeSubscriptionId']));

      // Notebook subcollection: users can only access their own notebook
      match /notebook/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Chat sessions subcollection: users can only access their own chat sessions
      match /chatSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Biology context: readable by any authenticated user, not writable from client
    match /biology_context/{topicId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
